# Warpbox Configuration
# ======================
# This file documents every possible configuration key with its default value
# and purpose. Uncomment and adjust values as needed.

torbox:
  # TorBox API key (required). Generate one from your TorBox account dashboard.
  api_key: "changeme"

server:
  # Network address the WebDAV server listens on.
  # Default: ":1412"
  listen_addr: ":1412"

  # Root URL path for the WebDAV endpoint.
  # Default: "/webdav"
  webdav_root: "/webdav"

cache:
  # Size of each chunk in the RAM buffer (in MB).
  # Files are split into chunks for Just-In-Time buffering. Larger chunks
  # reduce per-chunk overhead but increase RAM wastage for small reads.
  # Default: 16
  # chunk_size_mb: 16

  # Maximum RAM the buffer may consume (in MB).
  # The cache will not allocate more than this. When full, the eviction
  # strategy determines which chunks are freed.
  # Default: 512
  # max_ram_mb: 512

  # Time-to-live for cached chunks (in seconds).
  # Chunks older than this are eligible for eviction.
  # Default: 30
  # ttl_seconds: 30

  # Eviction strategy: "ttl" or "lru".
  #   ttl — evict oldest chunks first (by insertion time).
  #   lru — evict least-recently-used chunks first.
  # Default: "ttl"
  # eviction_strategy: "ttl"

  # How long to cache CDN download URLs (in minutes).
  # TorBox CDN URLs expire after a few hours. Setting this too high
  # will serve stale URLs and cause 404 errors.
  # Default: 120
  # cdn_url_ttl_minutes: 120

  # Automatically repair stale CDN URLs when a 404 is detected during proxy.
  # When enabled, a CDN URL that returns 404 will be refreshed transparently.
  # Default: true
  # cdn_url_auto_repair: true

  # Maximum number of retries for CDN proxy requests that fail with a 404
  # (after CDN URL repair). 0 means no retries.
  # Default: 2
  # cdn_url_repair_retries: 2

  # CDN URL fetch retry settings (for TorBox API errors, not CDN proxy errors).
  # Backoff base in seconds between retry attempts.
  # Default: 1
  # cdn_url_retry_backoff: 1
  # Maximum number of retry attempts when fetching a CDN URL from TorBox.
  # Default: 1
  # cdn_url_retry_attempts: 1

  # Negative cache TTL (in seconds).
  # When a CDN URL fetch fails, the failure is cached briefly to prevent
  # Plex/jellyfin retry storms from hammering the TorBox API.
  # Must be 1–300. Default: 30
  # negative_cache_ttl_seconds: 30

  # Circuit breaker: per-torrent failure tracking.
  # Number of failures within the window before the breaker trips.
  # Default: 5
  # circuit_breaker_failures: 5
  # Sliding window in seconds for counting failures.
  # Default: 60
  # circuit_breaker_window_seconds: 60
  # Minutes the breaker stays tripped before auto-reset.
  # Default: 5
  # circuit_breaker_stale_minutes: 5

  # Memory management settings.
  # Default: 5000
  # negative_cache_max_entries: 5000
  # Default: 2000
  # circuit_breaker_max_entries: 2000
  # How often to sweep expired cache entries (in seconds). Must be 10–3600.
  # Default: 60
  # cleanup_interval_seconds: 60
  # How often to log memory stats (in minutes). Must be 1–60.
  # Default: 5
  # memory_stats_interval_minutes: 5

  # CDN proxy settings.
  # Minimum chunk size in bytes to cache. Smaller chunks pass through.
  # Default: 16384 (16 KB)
  # min_chunk_bytes: 16384
  # Maximum concurrent CDN proxy connections per request.
  # Default: 8
  # max_cdn_connections: 8

throttle:
  # Maximum sustained TorBox API requests per minute.
  # The free TorBox plan allows 300 RPM. Setting this higher will result
  # in 429 errors. Must be 10–1000.
  # Default: 250
  requests_per_minute: 250

logging:
  # Output format: "text" for human-readable, "json" for structured logging.
  # Default: "text"
  # format: "text"

  # Log level: "debug", "info", "warn", or "error".
  # Default: "info"
  # level: "info"

sync:
  # How often to sync metadata from TorBox (in minutes).
  # Default: 5
  # interval_minutes: 5

  # Maximum number of files to fetch per sync cycle.
  # Default: 5000
  # limit: 5000

stats:
  # How often to record time-series stats snapshots (in seconds).
  # Snapshots include API call counts, memory usage, cache stats, etc.
  # These are displayed as sparkline charts on the landing page.
  # Default: 60
  # interval_seconds: 60

  # How long to retain stats rows (in hours).
  # Older rows are automatically pruned during each stats interval.
  # Default: 24
  # retention_hours: 24

  # How far back the landing page sparkline chart shows (in minutes).
  # Default: 60
  # chart_minutes: 60